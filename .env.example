# Google OAuth (for client portal)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
